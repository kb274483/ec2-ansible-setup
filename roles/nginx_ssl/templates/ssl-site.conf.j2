# {{ ssl_domain }} - HTTPS site config (managed by Ansible)

# HTTP → HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name {{ ssl_domain }}{% if ssl_extra_server_names is defined %} {{ ssl_extra_server_names | join(' ') }}{% endif %};

    # ACME challenge (留著未來如果改用 Let's Encrypt)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ ssl_domain }}{% if ssl_extra_server_names is defined %} {{ ssl_extra_server_names | join(' ') }}{% endif %};

    ssl_certificate     /etc/nginx/ssl/{{ ssl_domain }}/fullchain.crt;
    ssl_certificate_key /etc/nginx/ssl/{{ ssl_domain }}/private.key;

    # Mozilla Intermediate compatibility
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # HSTS(強制瀏覽器之後都用 HTTPS,確認 OK 再開)
    # add_header Strict-Transport-Security "max-age=63072000" always;

    root /var/www/html;
    index index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }

    # 範例:反向代理到後端 app
    # location /api/ {
    #     proxy_pass http://127.0.0.1:3000/;
    #     proxy_http_version 1.1;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
}
